[Unit]
Description=WikiBook Flask Application
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/projects/wikibook
Environment="PATH=/root/projects/wikibook/venv/bin"
EnvironmentFile=/root/projects/wikibook/.env
ExecStart=/root/projects/wikibook/venv/bin/gunicorn --config /root/projects/wikibook/gunicorn.conf.py app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target