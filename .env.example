SECRET_KEY=change-me
PORT=5009
HOST=0.0.0.0
APP_LOG_FILE=
DEBUG_TRACEBACK_TO_CLIENT=false
SYNC_SERVER_PORT=4444
# Local dev can use ws://localhost:4444. On a Linux server, set this to ws(s)://your-domain-or-ip:4444.
PUBLIC_SYNC_SERVER_URL=ws://localhost:4444

POSTGRES_DB=wikibook
POSTGRES_USER=wikibook
POSTGRES_PASSWORD=wikibook
DATABASE_URL=postgresql+psycopg://wikibook:wikibook@postgres:5432/wikibook
REDIS_URL=redis://redis:6379/0

GUNICORN_WORKERS=4
GUNICORN_PRELOAD=true

JUDGE_QUEUE_NAME=judge
JUDGE_DOCKER_HOST=tcp://dockerproxy:2375
JUDGE_RUNTIME_IMAGE=wikibook-judge-runtime:latest
JUDGE_DEFAULT_TIME_LIMIT_MS=2000
JUDGE_DEFAULT_MEMORY_LIMIT_MB=256
JUDGE_CONTAINER_CPUS=1.0
JUDGE_CONTAINER_PIDS_LIMIT=128
JUDGE_ALLOW_NETWORK=false
JUDGE_MAX_OUTPUT_BYTES=65536

AUTO_INIT_DB=false
